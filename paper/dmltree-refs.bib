@misc{liuBsnsingDecisionTree2022,
  title = {Bsnsing: {{A}} Decision Tree Induction Method Based on Recursive Optimal Boolean Rule Composition},
  shorttitle = {Bsnsing},
  author = {Liu, Yanchao},
  year = 2022,
  month = may,
  number = {arXiv:2205.15263},
  eprint = {2205.15263},
  primaryclass = {cs},
