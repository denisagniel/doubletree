@misc{carrieroExplainableAIHealthcare2025,
  title = {Explainable {{AI}} in {{Healthcare}}: To {{Explain}}, to {{Predict}}, or to {{Describe}}?},
  shorttitle = {Explainable {{AI}} in {{Healthcare}}},
  author = {Carriero, Alex and de Hond, Anne and Cappers, Bram and Paulovich, Fernando and Abeln, Sanne and Moons, Karel GM and van Smeden, Maarten},
  year = 2025,
  month = aug,
  number = {arXiv:2508.05753},
  eprint = {2508.05753},
  primaryclass = {stat},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2508.05753},
  urldate = {2025-08-11},
  abstract = {Explainable Artificial Intelligence (AI) methods are designed to provide information about how AI-based models make predictions. In healthcare, there is a widespread expectation that these methods will provide relevant and accurate information about a model's inner-workings to different stakeholders (ranging from patients and healthcare providers to AI and medical guideline developers). This is a challenging endeavour since what qualifies as relevant information may differ greatly depending on the stakeholder. For many stakeholders, relevant explanations are causal in nature, yet, explainable AI methods are often not able to deliver this information. Using the Describe-Predict-Explain framework, we argue that Explainable AI methods are good descriptive tools, as they may help to describe how a model works but are limited in their ability to explain why a model works in terms of true underlying biological mechanisms and cause-and-effect relations. This limits the suitability of explainable AI methods to provide actionable advice to patients or to judge the face validity of AI-based models.},
  archiveprefix = {arXiv},
  keywords = {Statistics - Methodology},
  file = {/Users/dagniel/Zotero/storage/8V5GKBX2/Carriero et al. - 2025 - Explainable AI in Healthcare to Explain, to Predict, or to Describe.pdf;/Users/dagniel/Zotero/storage/JETE9W5Y/2508.html}
}

